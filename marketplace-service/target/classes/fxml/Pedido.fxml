      </TextField>
      <Button fx:id="btnVoltar" onAction="#voltar" layoutX="30.0" layoutY="357.0" mnemonicParsing="false" prefHeight="26.0" prefWidth="76.0" style="-fx-background-color: #0F4C81; -fx-background-radius: 8;" text="Voltar" textFill="WHITE">
         <font><Font name="Arial Bold" size="14.0" /></font>
         <effect><ColorAdjust brightness="0.28" contrast="1.0" /></effect>
      </Button>
      <Button fx:id="btnOk" onAction="#confirmarPedido" layoutX="119.0" layoutY="357.0" mnemonicParsing="false" prefHeight="26.0" prefWidth="76.0" style="-fx-background-color: #0F4C81; -fx-background-radius: 8;" text="Ok" textFill="WHITE">
