      <TextField fx:id="txtNome" layoutX="31.0" layoutY="191.0" prefHeight="34.0" prefWidth="214.0" promptText="Nome" style="-fx-background-color: #909393; -fx-background-radius: 8; -fx-prompt-text-fill: #FFFFFF;">
