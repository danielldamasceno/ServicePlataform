<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<Pane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="630.0" prefWidth="472.0"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.serviceplataform.Interface.InterfaceController">
   <children>
      <ImageView fitHeight="630.0" fitWidth="472.0">
         <image>
            <Image url="@../images/Menu.png" />
         </image>
      </ImageView>
      <Button fx:id="btnPedido" onAction="#abrirPedido" layoutX="28.0" layoutY="296.0" mnemonicParsing="false" prefHeight="38.0" prefWidth="142.0" style="-fx-background-color: #00569f; -fx-background-radius: 8;" text="Fazer Pedido" textFill="WHITE">
         <font><Font name="Arial Bold" size="16.0" /></font>
      </Button>
      <Button fx:id="btnBuscar" onAction="#abrirPesquisar" layoutX="28.0" layoutY="341.0" mnemonicParsing="false" prefHeight="30.0" prefWidth="94.0" style="-fx-background-color: #00569f; -fx-background-radius: 8;" text="Buscar" textFill="WHITE">
         <font><Font name="Arial Bold" size="14.0" /></font>
      </Button>
      <Button fx:id="btnCadastrar" onAction="#abrirCadastrar" layoutX="14.0" layoutY="593.0" mnemonicParsing="false" prefHeight="23.0" prefWidth="121.0" style="-fx-background-color: #B3B3B3; -fx-background-radius: 8;" text="Cadastrar Serviço">
         <font><Font name="Arial Bold" size="12.0" /></font>
      </Button>
      <Button fx:id="btnListar" onAction="#abrirListar" layoutX="146.0" layoutY="593.0" mnemonicParsing="false" prefHeight="23.0" prefWidth="121.0" style="-fx-background-color: #B3B3B3; -fx-background-radius: 8;" text="Listar Serviços">
         <font><Font name="Arial Bold" size="12.0" /></font>
      </Button>
      <Button fx:id="btnSair" onAction="#sair" layoutX="382.0" layoutY="593.0" mnemonicParsing="false" prefHeight="23.0" prefWidth="76.0" style="-fx-background-color: #B3B3B3; -fx-background-radius: 8;" text="Sair">
         <font><Font name="Arial Bold" size="12.0" /></font>
      </Button>
   </children>
</Pane>
